{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "1.0.0",
  "description": "Browser configuration for Claude Native Messaging setup scripts",
  "extension_ids": {
    "official": {
      "id": "fcoeoabgfenejglbffodgkkbkcdhcgfn",
      "description": "Official Claude extension from Chrome Web Store"
    },
    "development": {
      "id": "dihbgbndebgnbjfmelmegjepbnkhlgni",
      "description": "Development/internal extension"
    },
    "staging": {
      "id": "dngcpimnedloihjnnfngkgjoidhnaolf",
      "description": "Staging extension"
    }
  },
  "claude_paths": {
    "macos": {
      "desktop": "/Applications/Claude.app/Contents/Helpers/chrome-native-host",
      "code": "$HOME/.claude/chrome/chrome-native-host"
    },
    "linux": {
      "desktop": [
        "/opt/Claude/chrome-native-host",
        "/usr/lib/claude/chrome-native-host",
        "$HOME/.local/share/Claude/chrome-native-host",
        "/snap/claude/current/chrome-native-host",
        "$HOME/.var/app/ai.anthropic.claude/chrome-native-host"
      ],
      "code": "$HOME/.claude/chrome/chrome-native-host"
    },
    "windows": {
      "desktop": [
        "%LOCALAPPDATA%\\Programs\\claude\\resources\\chrome-native-host.exe",
        "%LOCALAPPDATA%\\Claude\\chrome-native-host.exe",
        "%PROGRAMFILES%\\Claude\\chrome-native-host.exe",
        "%PROGRAMFILES(X86)%\\Claude\\chrome-native-host.exe"
      ],
      "code": "%USERPROFILE%\\.claude\\chrome\\chrome-native-host.exe"
    }
  },
  "browsers": [
